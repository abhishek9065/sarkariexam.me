# Production server root environment for GitHub Actions deploys.
# Copy this to .env on the server checkout root and fill in real values.
# This file is the production source of truth for scripts/deploy-*.sh and docker-compose.yml.
# Local app development uses backend/.env and frontend/.env.local instead.
#
# Critical current production assumptions:
# - PostgreSQL is required for the Prisma-backed content/editorial runtime.
# - Mongo/Cosmos is still required only while legacy compatibility routes and jobs remain active.
# - Redis is optional but recommended for caching/throttling once configured.

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRY=1d
# Optional: enforce issuer/audience on JWTs
JWT_ISSUER=sarkariexams-api
JWT_AUDIENCE=sarkariexams-clients

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://sarkariexams.me,https://www.sarkariexams.me

# Rate limiting (in milliseconds and max requests)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
# Security log retention period (hours).
SECURITY_LOG_RETENTION_HOURS=24
# Persist security logs into database collection.
SECURITY_LOG_PERSISTENCE_ENABLED=true
# Retain persisted security logs for this many days.
SECURITY_LOG_DB_RETENTION_DAYS=30
# Cleanup frequency for persisted security logs (minutes).
SECURITY_LOG_CLEANUP_INTERVAL_MINUTES=60

# Password hardening
PASSWORD_HISTORY_LIMIT=5
PASSWORD_BREACH_CHECK_ENABLED=true
PASSWORD_BREACH_CHECK_TIMEOUT_MS=2500

# SendGrid (for emails)
SENDGRID_API_KEY=your-sendgrid-api-key

# Redis cache / throttling / ephemeral queues
# Leave blank only if you intentionally accept in-memory fallbacks.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostgreSQL - PRIMARY structured runtime database
# Required for backend runtime, Prisma migrations, and tests.
# Set POSTGRES_PRISMA_URL directly. DATABASE_URL remains as a compatibility fallback only.
POSTGRES_PRISMA_URL=postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL=

# Mongo / Cosmos legacy bridge
# Only set one of these while legacy compatibility paths still need them.
COSMOS_CONNECTION_STRING=mongodb://accountname:password@accountname.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false
MONGODB_URI=
COSMOS_DATABASE_NAME=sarkari_db

# Error Tracking (Sentry.io)
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/project-id

# Infrastructure Monitoring (Datadog)
# Get API key from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=your-datadog-api-key
# Site options: datadoghq.com (US), datadoghq.eu (EU), us5.datadoghq.com (US5)
DD_SITE=datadoghq.com

# Metrics endpoint protection. Set in production to enable protected /metrics access.
# If omitted in production, the /metrics endpoint is intentionally disabled.
METRICS_TOKEN=

# Protected frontend cache revalidation.
# Backend uses FRONTEND_REVALIDATE_URL + FRONTEND_REVALIDATE_TOKEN.
# Frontend receives the same token as REVALIDATE_TOKEN via docker-compose.yml.
FRONTEND_REVALIDATE_URL=http://frontend:3000/api/revalidate
FRONTEND_REVALIDATE_TOKEN=replace-with-a-long-random-token
CONTENT_CACHE_REVALIDATE_SECONDS=300

# Public runtime URLs exposed to frontend/admin builds
NEXT_PUBLIC_API_URL=https://sarkariexams.me/api
NEXT_PUBLIC_ADMIN_URL=https://sarkariexams.me/admin
NEXT_PUBLIC_FRONTEND_URL=https://sarkariexams.me

# Frontend feature flags
FEATURE_SEARCH_OVERLAY_V2=true
FEATURE_COMPARE_JOBS_V2=true
FEATURE_TRACKER_API_V2=true
FEATURE_DASHBOARD_WIDGETS_V2=true

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
FRONTEND_URL=https://sarkariexams.me

# Background schedulers (optional tuning)
# Digest sender scheduler
DIGEST_SCHEDULER_INTERVAL_MS=900000
DIGEST_DAILY_HOUR_UTC=7
DIGEST_WEEKLY_DAY_UTC=1
DIGEST_WEEKLY_HOUR_UTC=8
DIGEST_MAX_ITEMS=12

# Tracked/bookmarked deadline reminders scheduler
TRACKER_REMINDER_INTERVAL_MS=1800000
TRACKER_REMINDER_LEAD_DAYS=3
TRACKER_REMINDER_MAX_EMAIL_ITEMS=10

# Saved search alerts scheduler
SAVED_SEARCH_ALERT_INTERVAL_MS=1800000
SAVED_SEARCH_ALERT_MAX_SEARCHES=300
SAVED_SEARCH_ALERT_MAX_EMAIL_ITEMS=12
SAVED_SEARCH_ALERT_DAILY_WINDOW_DAYS=1
SAVED_SEARCH_ALERT_WEEKLY_WINDOW_DAYS=7
SAVED_SEARCH_ALERT_INSTANT_WINDOW_DAYS=1
SAVED_SEARCH_ALERT_INSTANT_COOLDOWN_MINUTES=60
