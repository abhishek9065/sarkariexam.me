# Local backend development only.
# Do not use this file as the production deploy source of truth.
PORT=5000

# PostgreSQL is required for the current backend content and editorial layer.
POSTGRES_PRISMA_URL=postgresql://postgres:postgres@localhost:5432/sarkari_content?schema=public

# Legacy Mongo / Cosmos bridge for compatibility-only flows.
# Format: mongodb://username:password@host:port/database
# Use COSMOS_CONNECTION_STRING or MONGODB_URI only while legacy routes/jobs still depend on Mongo-compatible storage.
COSMOS_CONNECTION_STRING=mongodb://localhost:27017/sarkari_db
MONGODB_URI=
COSMOS_DATABASE_NAME=sarkari_db

JWT_SECRET=change-me
JWT_EXPIRY=1d
# Set in production to enable protected /metrics access.
# If omitted in production, the /metrics endpoint is disabled.
METRICS_TOKEN=
SECURITY_LOG_RETENTION_HOURS=24
SECURITY_LOG_PERSISTENCE_ENABLED=true
SECURITY_LOG_DB_RETENTION_DAYS=30
SECURITY_LOG_CLEANUP_INTERVAL_MINUTES=60
PASSWORD_HISTORY_LIMIT=5
PASSWORD_BREACH_CHECK_ENABLED=true
PASSWORD_BREACH_CHECK_TIMEOUT_MS=2500

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://sarkariexams.me,https://www.sarkariexams.me

# Rate limiting (in milliseconds and max requests)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
FRONTEND_URL=http://localhost:3000
FRONTEND_REVALIDATE_URL=
FRONTEND_REVALIDATE_TOKEN=

