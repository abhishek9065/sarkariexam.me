generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum PostType {
  JOB          @map("job")
  RESULT       @map("result")
  ADMIT_CARD   @map("admit_card")
  ANSWER_KEY   @map("answer_key")
  ADMISSION    @map("admission")
  SCHOLARSHIP  @map("scholarship")
  BOARD_RESULT @map("board_result")
  SYLLABUS     @map("syllabus")
}

enum WorkflowStatus {
  DRAFT      @map("draft")
  IN_REVIEW  @map("in_review")
  APPROVED   @map("approved")
  PUBLISHED  @map("published")
  ARCHIVED   @map("archived")
}

enum ImportantDateKind {
  APPLICATION_START @map("application_start")
  LAST_DATE         @map("last_date")
  EXAM_DATE         @map("exam_date")
  RESULT_DATE       @map("result_date")
  ADMIT_CARD        @map("admit_card")
  COUNSELLING       @map("counselling")
  OTHER             @map("other")
}

enum TrustTag {
  NEW       @map("new")
  HOT       @map("hot")
  UPDATE    @map("update")
  LAST_DATE @map("last_date")
}

enum SubscriptionFrequency {
  INSTANT @map("instant")
  DAILY   @map("daily")
  WEEKLY  @map("weekly")
}

enum ContentPageType {
  AUXILIARY       @map("auxiliary")
  INFO            @map("info")
  COMMUNITY       @map("community")
  CATEGORY_META   @map("category_meta")
  RESOURCE_META   @map("resource_meta")
  STATE_DIRECTORY @map("state_directory")
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  kind             String?
  shortName        String?
  officialWebsite  String?
  description      String?
  priority         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  exams            Exam[]
  posts            Post[]
  subscriptionPrefs SubscriptionOrganization[]

  @@index([name])
  @@index([priority, name])
  @@map("organizations")
}

model State {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  code              String?
  region            String?
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  postStates        PostState[]
  subscriptionPrefs SubscriptionState[]

  @@index([name])
  @@index([priority, name])
  @@map("states")
}

model Category {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  postCategories    PostCategory[]
  subscriptionPrefs SubscriptionCategory[]

  @@index([name])
  @@index([priority, name])
  @@map("categories")
}

model Qualification {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  level             String?
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  postQualifications PostQualification[]
  eligibilityRules   EligibilityRule[]
  subscriptionPrefs  SubscriptionQualification[]

  @@index([name])
  @@index([priority, name])
  @@map("qualifications")
}

model Exam {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  level          String?
  organizationId String?
  description    String?
  priority       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  posts          Post[]

  @@index([name])
  @@index([organizationId, name])
  @@map("exams")
}

model College {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  shortName       String?
  stateCode       String?
  collegeType     String?
  officialWebsite String?
  description     String?
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           Post[]
  programs        Program[]
  admissionDetails AdmissionDetail[]

  @@index([name])
  @@index([priority, name])
  @@map("colleges")
}

model Program {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  level            String?
  department       String?
  durationLabel    String?
  mode             String?
  intake           String?
  description      String?
  collegeId        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  college          College? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  posts            Post[]
  admissionDetails AdmissionDetail[]

  @@index([name])
  @@index([collegeId, name])
  @@map("programs")
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postTags  PostTag[]

  @@index([name])
  @@map("tags")
}

model Post {
  id                   String         @id @default(cuid())
  legacyAnnouncementId String?
  legacyId             String?
  title                String
  slug                 String         @unique
  legacySlugs          String[]       @default([])
  type                 PostType
  status               WorkflowStatus @default(DRAFT)
  summary              String
  shortInfo            String?
  body                 String?
  contentJson          Json?

  organizationId       String?
  institutionId        String?
  examId               String?
  programId            String?

  location             String?
  salary               String?
  postCount            String?
  applicationStartDate String?
  lastDate             String?
  examDate             String?
  resultDate           String?

  expiresAt            DateTime?
  archivedAt           DateTime?
  publishedAt          DateTime?

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  createdBy            String?
  updatedBy            String?
  approvedBy           String?
  publishedBy          String?
  currentVersion       Int            @default(1)

  searchText           String         @default("")
  sourceNote           String?
  verificationNote     String?
  updatedLabel         String?
  correctionNote       String?

  tag                  TrustTag?
  isUrgent             Boolean        @default(false)
  isNew                Boolean        @default(false)
  isLastDate           Boolean        @default(false)
  isFeatured           Boolean        @default(false)

  homeSection          String?
  stickyRank           Int?
  highlight            Boolean        @default(false)
  trendingScore        Int?

  seoTitle             String?
  seoDescription       String?
  seoCanonicalPath     String?
  seoIndexable         Boolean        @default(true)
  seoOgImage           String?

  organization         Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  institution          College?       @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  exam                 Exam?          @relation(fields: [examId], references: [id], onDelete: SetNull)
  program              Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)

  postCategories       PostCategory[]
  postStates           PostState[]
  postQualifications   PostQualification[]
  postTags             PostTag[]

  officialSources      OfficialSource[]
  importantDates       ImportantDate[]
  eligibilityRules     EligibilityRule[]
  feeRules             FeeRule[]
  vacancyRows          VacancyRow[]
  admissionDetails     AdmissionDetail?

  versions             PostVersion[]
  auditLogs            AuditLog[]
  slugAliases          SlugAlias[]
  alertDispatchLogs    AlertDispatchLog[]

  @@index([status, publishedAt])
  @@index([type, status, publishedAt])
  @@index([isFeatured, status, publishedAt])
  @@index([isUrgent, status, publishedAt])
  @@index([status, updatedAt])
  @@index([organizationId, status, publishedAt])
  @@index([institutionId, status, publishedAt])
  @@index([examId, status, publishedAt])
  @@index([programId, status, publishedAt])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("posts")
}

model PostCategory {
  id         String   @id @default(cuid())
  postId     String
  categoryId String
  createdAt  DateTime @default(now())

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([postId, categoryId])
  @@index([categoryId, postId])
  @@map("post_categories")
}

model PostState {
  id        String   @id @default(cuid())
  postId    String
  stateId   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([postId, stateId])
  @@index([stateId, postId])
  @@map("post_states")
}

model PostQualification {
  id              String        @id @default(cuid())
  postId          String
  qualificationId String
  createdAt       DateTime      @default(now())

  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@unique([postId, qualificationId])
  @@index([qualificationId, postId])
  @@map("post_qualifications")
}

model PostTag {
  id        String   @id @default(cuid())
  postId    String
  tagId     String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId, postId])
  @@map("post_tags")
}

model OfficialSource {
  id         String   @id @default(cuid())
  postId     String
  label      String
  url        String
  sourceType String?
  isPrimary  Boolean  @default(false)
  capturedAt DateTime?
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, isPrimary, position])
  @@index([url])
  @@map("official_sources")
}

model ImportantDate {
  id         String            @id @default(cuid())
  postId     String
  kind       ImportantDateKind?
  label      String
  value      String
  sortDate   DateTime?
  isPrimary  Boolean           @default(false)
  note       String?
  position   Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  post       Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, kind, sortDate])
  @@index([sortDate])
  @@map("important_dates")
}

model EligibilityRule {
  id              String        @id @default(cuid())
  postId          String
  qualificationId String?
  label           String
  description     String
  minAge          Int?
  maxAge          Int?
  relaxationNote  String?
  position        Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  qualification   Qualification? @relation(fields: [qualificationId], references: [id], onDelete: SetNull)

  @@index([postId, position])
  @@index([qualificationId])
  @@map("eligibility_rules")
}

model FeeRule {
  id          String   @id @default(cuid())
  postId      String
  category    String
  amount      String
  currency    String?  @default("INR")
  paymentNote String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, position])
  @@map("fee_rules")
}

model VacancyRow {
  id          String   @id @default(cuid())
  postId      String
  postName    String
  department  String?
  category    String?
  vacancies   String
  payLevel    String?
  salaryNote  String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, position])
  @@map("vacancy_rows")
}

model AdmissionDetail {
  id                String   @id @default(cuid())
  postId            String   @unique
  collegeId         String?
  programId         String?
  intake            String?
  counsellingRounds Json?
  applicationWindow Json?
  domicilePolicy    String?
  reservationPolicy String?
  seatMatrix        Json?
  scholarshipNote   String?
  hostelInfo        String?
  correctionNote    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  college           College? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  program           Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([collegeId])
  @@index([programId])
  @@map("admission_details")
}

model PostVersion {
  id        String   @id @default(cuid())
  postId    String
  version   Int
  note      String?
  reason    String?
  actorId   String?
  snapshot  Json
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, version])
  @@index([postId, createdAt])
  @@map("post_versions")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  postId     String?
  action     String
  actorId    String?
  actorRole  String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  post       Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model WorkflowLogEntry {
  id             String   @id
  announcementId String   @map("announcement_id")
  action         String
  actor          String
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([announcementId, createdAt], map: "app_workflow_logs_announcement_created_idx")
  @@map("app_workflow_logs")
}

model SiteSettingRecord {
  id        String   @id
  payload   Json     @default("{}")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_site_settings")
}

model PushSubscriptionEntry {
  id        String   @id
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "app_push_subscriptions_user_created_idx")
  @@map("app_push_subscriptions")
}

model BookmarkEntry {
  id             String   @id
  userId         String   @map("user_id")
  announcementId String   @map("announcement_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, announcementId])
  @@index([userId, createdAt], map: "app_bookmarks_user_created_idx")
  @@index([announcementId], map: "app_bookmarks_announcement_idx")
  @@map("app_bookmarks")
}

model ErrorReportEntry {
  id             String   @id
  errorId        String   @map("error_id")
  message        String
  pageUrl        String?  @map("page_url")
  userAgent      String?  @map("user_agent")
  note           String?
  stack          String?
  componentStack String?  @map("component_stack")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")
  userId         String?  @map("user_id")
  userEmail      String?  @map("user_email")
  status         String   @default("new")
  reviewNote     String?  @map("review_note")
  assigneeEmail  String?  @map("assignee_email")
  release        String?
  requestId      String?  @map("request_id")
  sentryEventUrl String?  @map("sentry_event_url")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?  @map("resolved_by")

  @@index([status, createdAt], map: "app_error_reports_status_created_idx")
  @@map("app_error_reports")
}

model NotificationCampaignEntry {
  id           String   @id
  title        String
  body         String
  url          String?
  segmentType  String   @map("segment_type")
  segmentValue String   @map("segment_value")
  status       String   @default("draft")
  sentCount    Int      @default(0) @map("sent_count")
  failedCount  Int      @default(0) @map("failed_count")
  openCount    Int      @default(0) @map("open_count")
  clickCount   Int      @default(0) @map("click_count")
  scheduledAt  DateTime? @map("scheduled_at")
  sentAt       DateTime? @map("sent_at")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  abTest       Json?    @map("ab_test")

  @@index([status, scheduledAt], map: "app_notification_campaigns_status_scheduled_idx")
  @@index([createdAt], map: "app_notification_campaigns_created_idx")
  @@map("app_notification_campaigns")
}

model UserNotificationEntry {
  id             String   @id
  userId         String   @map("user_id")
  announcementId String   @map("announcement_id")
  title          String
  type           String
  slug           String?
  organization   String?
  source         String
  createdAt      DateTime @default(now()) @map("created_at")
  readAt         DateTime? @map("read_at")

  @@unique([userId, announcementId, source])
  @@index([userId, createdAt], map: "app_user_notifications_user_created_idx")
  @@index([userId, readAt], map: "app_user_notifications_unread_idx")
  @@map("app_user_notifications")
}

model SavedSearchEntry {
  id                   String   @id
  userId               String   @map("user_id")
  name                 String
  query                String   @default("")
  filters              Json?
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  frequency            String   @default("daily")
  lastNotifiedAt       DateTime? @map("last_notified_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([userId, updatedAt], map: "app_saved_searches_user_updated_idx")
  @@map("app_saved_searches")
}

model TrackedApplicationEntry {
  id             String   @id
  userId         String   @map("user_id")
  announcementId String?  @map("announcement_id")
  slug           String
  type           String
  title          String
  organization   String?
  deadline       DateTime?
  status         String
  notes          String?
  reminderAt     DateTime? @map("reminder_at")
  trackedAt      DateTime @default(now()) @map("tracked_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, slug])
  @@index([userId, updatedAt], map: "app_tracked_applications_user_updated_idx")
  @@map("app_tracked_applications")
}

model UserProfileEntry {
  id                       String   @id
  userId                   String   @unique @map("user_id")
  preferredCategories      String[] @default([]) @map("preferred_categories")
  preferredQualifications   String[] @default([]) @map("preferred_qualifications")
  preferredLocations       String[] @default([]) @map("preferred_locations")
  preferredOrganizations   String[] @default([]) @map("preferred_organizations")
  ageGroup                 String?  @map("age_group")
  educationLevel           String?  @map("education_level")
  experienceYears          Int      @default(0) @map("experience_years")
  emailNotifications       Boolean  @default(true) @map("email_notifications")
  pushNotifications        Boolean  @default(false) @map("push_notifications")
  notificationFrequency    String   @default("daily") @map("notification_frequency")
  alertWindowDays          Int      @default(7) @map("alert_window_days")
  alertMaxItems            Int      @default(6) @map("alert_max_items")
  profileComplete          Boolean  @default(false) @map("profile_complete")
  onboardingCompleted      Boolean  @default(false) @map("onboarding_completed")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_user_profiles")
}

model UserAccountEntry {
  id                            String   @id
  email                         String   @unique
  username                      String
  passwordHash                  String   @map("password_hash")
  passwordHistory               Json     @default("[]") @map("password_history")
  role                          String   @default("user")
  isActive                      Boolean  @default(true) @map("is_active")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @default(now()) @updatedAt @map("updated_at")
  lastLogin                     DateTime? @map("last_login")
  twoFactorEnabled              Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret               String?  @map("two_factor_secret")
  twoFactorTempSecret           String?  @map("two_factor_temp_secret")
  twoFactorVerifiedAt           DateTime? @map("two_factor_verified_at")
  twoFactorBackupCodes          Json     @default("[]") @map("two_factor_backup_codes")
  twoFactorBackupCodesUpdatedAt DateTime? @map("two_factor_backup_codes_updated_at")

  @@index([role, isActive], map: "app_users_role_active_idx")
  @@index([createdAt], map: "app_users_created_idx")
  @@map("app_users")
}

model ReminderDispatchLogEntry {
  id             String   @id
  dedupeKey      String   @unique @map("dedupe_key")
  userId         String   @map("user_id")
  channel        String
  source         String
  announcementId String   @map("announcement_id")
  deadlineDate   String?  @map("deadline_date")
  sentAt         DateTime @default(now()) @map("sent_at")

  @@index([userId, sentAt], map: "app_reminder_dispatch_logs_user_sent_idx")
  @@map("app_reminder_dispatch_logs")
}

model SlugAlias {
  id         String   @id @default(cuid())
  postId     String
  slug       String   @unique
  isLegacy   Boolean  @default(true)
  createdAt  DateTime @default(now())

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("slug_aliases")
}

model ContentPage {
  id               String         @id @default(cuid())
  slug             String         @unique
  pageType         ContentPageType
  title            String
  eyebrow          String?
  description      String?
  headerColor      String?
  layoutVariant    String?
  payload          Json
  status           WorkflowStatus @default(DRAFT)
  seoTitle         String?
  seoDescription   String?
  seoCanonicalPath String?
  seoIndexable     Boolean        @default(true)
  publishedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  updatedBy        String?

  @@index([pageType, status, updatedAt])
  @@index([expiresAt])
  @@map("content_pages")
}

model Subscription {
  id                 String                @id @default(cuid())
  email              String                @unique
  verified           Boolean               @default(false)
  isActive           Boolean               @default(true)
  frequency          SubscriptionFrequency @default(DAILY)
  verificationToken  String?
  unsubscribeToken   String                @unique
  source             String?
  alertCount         Int                   @default(0)
  lastAlertedAt          DateTime?
  lastDigestDailySentAt  DateTime?              @map("last_digest_daily_sent_at")
  lastDigestWeeklySentAt DateTime?              @map("last_digest_weekly_sent_at")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  categoryPrefs      SubscriptionCategory[]
  statePrefs         SubscriptionState[]
  organizationPrefs  SubscriptionOrganization[]
  qualificationPrefs SubscriptionQualification[]
  postTypePrefs      SubscriptionPostType[]
  dispatchLogs       AlertDispatchLog[]

  @@index([isActive, verified, frequency])
  @@index([frequency, lastDigestDailySentAt])
  @@index([frequency, lastDigestWeeklySentAt])
  @@map("subscriptions")
}

model SubscriptionCategory {
  id             String       @id @default(cuid())
  subscriptionId String
  categoryId     String

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, categoryId])
  @@index([categoryId, subscriptionId])
  @@map("subscription_categories")
}

model SubscriptionState {
  id             String       @id @default(cuid())
  subscriptionId String
  stateId        String

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  state          State        @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, stateId])
  @@index([stateId, subscriptionId])
  @@map("subscription_states")
}

model SubscriptionOrganization {
  id             String       @id @default(cuid())
  subscriptionId String
  organizationId String

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, organizationId])
  @@index([organizationId, subscriptionId])
  @@map("subscription_organizations")
}

model SubscriptionQualification {
  id              String        @id @default(cuid())
  subscriptionId  String
  qualificationId String

  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, qualificationId])
  @@index([qualificationId, subscriptionId])
  @@map("subscription_qualifications")
}

model SubscriptionPostType {
  id             String   @id @default(cuid())
  subscriptionId String
  postType       PostType

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, postType])
  @@index([postType, subscriptionId])
  @@map("subscription_post_types")
}

model AlertDispatchLog {
  id             String   @id @default(cuid())
  subscriptionId String
  postId         String?
  channel        String
  status         String
  messageId      String?
  metadata       Json?
  dispatchedAt   DateTime @default(now())
  createdAt      DateTime @default(now())

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  post           Post?        @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, dispatchedAt])
  @@index([postId, dispatchedAt])
  @@map("alert_dispatch_logs")
}

model AnalyticsEvent {
  id             String   @id @default(cuid())
  type           String
  announcementId String?  @map("announcement_id")
  userId         String?  @map("user_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([announcementId, type, createdAt])
  @@index([userId, createdAt])
  @@map("app_analytics_events")
}

model AnalyticsRollup {
  id                        String   @id @default(cuid())
  date                      String   @unique
  viewCount                 Int      @default(0) @map("view_count")
  listingViews              Int      @default(0) @map("listing_views")
  cardClicks                Int      @default(0) @map("card_clicks")
  categoryClicks            Int      @default(0) @map("category_clicks")
  filterApplies             Int      @default(0) @map("filter_applies")
  searchCount               Int      @default(0) @map("search_count")
  bookmarkAdds              Int      @default(0) @map("bookmark_adds")
  bookmarkRemoves           Int      @default(0) @map("bookmark_removes")
  registrations             Int      @default(0) @map("registrations")
  subscriptionsVerified     Int      @default(0) @map("subscriptions_verified")
  subscriptionsUnsubscribed Int      @default(0) @map("subscriptions_unsubscribed")
  savedSearches             Int      @default(0) @map("saved_searches")
  digestPreviews            Int      @default(0) @map("digest_previews")
  digestClicks              Int      @default(0) @map("digest_clicks")
  deepLinkClicks            Int      @default(0) @map("deep_link_clicks")
  alertsViewed              Int      @default(0) @map("alerts_viewed")
  pushSubscribeAttempts     Int      @default(0) @map("push_subscribe_attempts")
  pushSubscribeSuccesses    Int      @default(0) @map("push_subscribe_successes")
  pushSubscribeFailures     Int      @default(0) @map("push_subscribe_failures")
  announcementCount         Int      @default(0) @map("announcement_count")
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([date])
  @@map("app_analytics_rollups")
}

model SecurityLog {
  id             String   @id @default(cuid())
  ipAddress      String   @map("ip_address")
  eventType      String   @map("event_type")
  endpoint       String
  metadata       Json?
  incidentStatus String   @default("new") @map("incident_status")
  assigneeEmail  String?  @map("assignee_email")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([ipAddress, createdAt])
  @@map("app_security_logs")
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  email     String?
  subject   String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("app_user_feedback")
}

model CommunityComment {
  id             String    @id @default(cuid())
  postId         String?   @map("post_id")
  userId         String?   @map("user_id")
  username       String?
  body           String
  status         String    @default("pending")
  moderatedAt    DateTime? @map("moderated_at")
  moderatedBy    String?   @map("moderated_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([postId, status])
  @@map("app_community_comments")
}
