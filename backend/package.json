{
  "name": "sarkari-backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:ci": "vitest run --maxWorkers=2 --retry=1 && npm run verify:openapi-parity",
    "verify:openapi-parity": "tsx scripts/verify-openapi-parity.ts"
  },
  "engines": {
    "node": ">=22.x"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.45.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.0",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cookie-parser": "^1.4.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^17.4.0",
    "mongodb-memory-server": "^11.0.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "axios": "^1.13.5",
    "bn.js": "^4.12.3",
    "fast-xml-parser": "^5.3.4",
    "qs": "^6.15.0",
    "minimatch": "^10.2.3"
  }
}
