# Frontend local development only.
# Copy to .env.local and update values as needed.
# Production Docker deploys use the server root .env instead.

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000
# Local frontend uses bundled fallback content unless this is true.
CONTENT_API_ENABLED=false

# Admin Console URL  
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
REVALIDATE_TOKEN=
CONTENT_CACHE_REVALIDATE_SECONDS=300
